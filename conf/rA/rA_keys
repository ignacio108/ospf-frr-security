frr version 10.2.1
frr defaults traditional
hostname rA
log syslog informational
ip forwarding
ipv6 forwarding
service integrated-vtysh-config
!
key chain 1
 key 1
  cryptographic-algorithm hmac-sha-256
  key-string clave
 exit
exit
!
key chain 2
 key 1
  cryptographic-algorithm hmac-sha-256
  key-string clave2
 exit
exit
!
interface eth1
 ip ospf area 1
 ip ospf authentication key-chain 2
 ip ospf network point-to-multipoint
 ip ospf priority 10
 ipv6 ospf6 area 1
 ipv6 ospf6 authentication keychain 2
 ipv6 ospf6 network point-to-multipoint
 ipv6 ospf6 priority 10
exit
!
interface eth2
 ip ospf area 0
 ip ospf authentication key-chain 1
 ip ospf network point-to-point
 ip ospf priority 10
 ipv6 ospf6 area 0
 ipv6 ospf6 authentication keychain 1
 ipv6 ospf6 network point-to-point
 ipv6 ospf6 priority 10
exit
!
interface eth3
 ip ospf area 0
 ip ospf authentication key-chain 1
 ip ospf network point-to-point
 ip ospf priority 10
 ipv6 ospf6 area 0
 ipv6 ospf6 authentication keychain 1
 ipv6 ospf6 network point-to-point
 ipv6 ospf6 priority 10
exit
!
interface lo
 ip address 10.7.0.1/24
 ip ospf area 0
 ip ospf passive
 ipv6 address fd80:e42c:3ce3::1/128
 ipv6 ospf6 area 0
exit
!
router ospf
 ospf router-id 10.7.0.1
 area 0 range 10.8.1.0/24
 area 1 range 10.7.1.0/24
exit
!
router ospf6
 ospf6 router-id 10.7.0.1
 area 0 range fd80:e42c:3ce3:a770::/64
 area 1 range fd80:e42c:3ce3:a66a::/64
 summary-address fd80:e42c:3ce3:a66a::/64
 summary-address fd80:e42c:3ce3:a770::/64
exit
!



